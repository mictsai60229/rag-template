# RAG Data Import Pipeline — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit the .env file — it contains secrets.

# ── Embedding Provider ─────────────────────────────────────────────────────────
# API key for OpenAI Embeddings (required when EMBEDDING_PROVIDER=openai)
OPENAI_API_KEY=sk-...

# Embedding provider: "openai" or "huggingface"
EMBEDDING_PROVIDER=openai

# Model name for the embedding provider
#   OpenAI:       text-embedding-3-small | text-embedding-3-large
#   HuggingFace:  sentence-transformers/all-MiniLM-L6-v2 (or any compatible model)
EMBEDDING_MODEL=text-embedding-3-small

# Number of texts to embed in a single API call (tune to stay within rate limits)
EMBEDDING_BATCH_SIZE=32

# ── OpenSearch ─────────────────────────────────────────────────────────────────
# Hostname or IP of the OpenSearch node
OPENSEARCH_HOST=localhost

# OpenSearch REST API port
OPENSEARCH_PORT=9200

# Name of the index that will hold chunk documents
OPENSEARCH_INDEX=rag-chunks

# ── Chunking ───────────────────────────────────────────────────────────────────
# Chunking strategy: fixed | recursive | sentence | semantic
CHUNKING_STRATEGY=recursive

# Target size of each chunk in characters (for fixed/recursive strategies)
CHUNK_SIZE=512

# Number of characters to overlap between consecutive chunks
CHUNK_OVERLAP=64

# ── Environment ────────────────────────────────────────────────────────────────
# Runtime environment: dev | staging | production
ENV=dev
