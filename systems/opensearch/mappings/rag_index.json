{
  "settings": {
    "index.knn": true,
    "number_of_shards": 1,
    "number_of_replicas": 1
  },
  "mappings": {
    "properties": {
      "chunk_id":    { "type": "keyword" },
      "doc_id":      { "type": "keyword" },
      "content":     { "type": "text", "analyzer": "standard" },
      "_comment_dimension": "dimension must match the configured embedding model output size; default 1536 matches text-embedding-3-small; recreate the index if this value changes",
      "embedding":   {
        "type": "knn_vector",
        "dimension": 1536,
        "method": {
          "name": "hnsw",
          "space_type": "cosinesimil",
          "engine": "nmslib",
          "parameters": {
            "ef_construction": 128,
            "m": 16
          }
        }
      },
      "source":      { "type": "keyword" },
      "doc_type":    { "type": "keyword" },
      "page_number": { "type": "integer" },
      "chunk_index": { "type": "integer" },
      "ingested_at": { "type": "date" }
    }
  }
}
