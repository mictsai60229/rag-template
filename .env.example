# RAG Template — Root Environment Variables
# Copy this file to .env and fill in real values before running docker compose.
# Never commit the .env file — it contains secrets.

# ============================================================
# OpenSearch
# ============================================================
OPENSEARCH_HOST=opensearch          # Service name on rag-network (use localhost outside Docker)
OPENSEARCH_PORT=9200                # OpenSearch REST API port
OPENSEARCH_INDEX=rag-chunks         # Name of the index that stores ChunkDocuments
# OPENSEARCH_USERNAME=admin         # Optional: basic-auth username (leave blank for no-auth dev)
# OPENSEARCH_PASSWORD=changeme      # Optional: basic-auth password

# ============================================================
# Embedding Provider (shared by Backend and Import pipeline)
# ============================================================
EMBEDDING_PROVIDER=openai           # openai | huggingface
EMBEDDING_MODEL=text-embedding-3-small  # Model name passed to the embedding provider
#   OpenAI:       text-embedding-3-small | text-embedding-3-large
#   HuggingFace:  sentence-transformers/all-MiniLM-L6-v2 (or any compatible model)
EMBEDDING_BATCH_SIZE=32             # Max texts per batch when calling the embedding API

# ============================================================
# OpenAI (used by both the OpenAI embedder and OpenAI LLM provider)
# ============================================================
OPENAI_API_KEY=sk-...               # Get from platform.openai.com — never commit a real value

# ============================================================
# Backend — LLM
# ============================================================
LLM_MODEL=gpt-4o-mini              # Chat completion model name

# ============================================================
# Backend — Retrieval
# ============================================================
RETRIEVAL_MODE=hybrid               # vector | keyword | hybrid
TOP_K=5                             # Number of chunks to retrieve per query
KEYWORD_BOOST=0.3                   # Weight of the BM25 keyword clause in hybrid mode

# ============================================================
# Backend — API Security
# ============================================================
# API_KEY: Request auth header value (X-API-Key); leave blank to disable auth in dev
API_KEY=
ENV=dev                             # dev | production — disables auth checks when set to dev

# ============================================================
# Backend — Logging
# ============================================================
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR

# ============================================================
# Import Pipeline — Chunking
# ============================================================
CHUNKING_STRATEGY=recursive         # fixed | recursive | sentence | semantic
CHUNK_SIZE=512                      # Target size of each chunk in characters
CHUNK_OVERLAP=64                    # Number of characters to overlap between consecutive chunks
